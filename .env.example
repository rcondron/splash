# =============================================================================
# SPLASH - Maritime Chartering Platform
# Root Environment Variables
# =============================================================================

# Docker Compose
COMPOSE_PROJECT_NAME=splash

# PostgreSQL
POSTGRES_DB=splash_dev
POSTGRES_USER=splash
POSTGRES_PASSWORD=splash_dev_password
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Backend
BACKEND_PORT=3001
NODE_ENV=development

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
