# =============================================================================
# SPLASH - Maritime Chartering Platform
# Root Environment Variables
# =============================================================================

# Docker Compose
COMPOSE_PROJECT_NAME=splash

# PostgreSQL
POSTGRES_DB=splash_dev
POSTGRES_USER=splash
POSTGRES_PASSWORD=splash_dev_password
POSTGRES_PORT=5433

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380

# Backend
BACKEND_PORT=3011
NODE_ENV=development

# Frontend
FRONTEND_PORT=3010
NEXT_PUBLIC_API_URL=http://localhost:3011
NEXT_PUBLIC_WS_URL=ws://localhost:3011
