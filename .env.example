# =============================================================================
# SPLASH - Maritime Chartering Platform
# Root Environment Variables
# =============================================================================

# Docker Compose
COMPOSE_PROJECT_NAME=splash

# Frontend
FRONTEND_PORT=3010

# URL of the Quint API (Flask + Matrix/Synapse). The frontend proxies
# /quint-api, /quint-v1, /quint-v2, and /_matrix to this host via the
# Next.js rewrites in frontend/next.config.mjs.
NEXT_PUBLIC_QUINT_HOST=http://localhost:8888
