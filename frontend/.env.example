# URL of the Quint API server (Flask + Matrix/Synapse).
# Browser requests go through Next.js rewrites defined in next.config.mjs:
#   /quint-api/*   -> ${NEXT_PUBLIC_QUINT_HOST}/api/*
#   /quint-v1/*    -> ${NEXT_PUBLIC_QUINT_HOST}/v1/*
#   /quint-v2/*    -> ${NEXT_PUBLIC_QUINT_HOST}/v2/*
#   /_matrix/*     -> ${NEXT_PUBLIC_QUINT_HOST}/_matrix/*
NEXT_PUBLIC_QUINT_HOST=http://localhost:8888
