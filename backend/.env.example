# =============================================================================
# SPLASH Backend - Environment Variables
# =============================================================================

# Application
NODE_ENV=development
PORT=3011

# Public URL of this API (used in avatar links; match NEXT_PUBLIC_API_URL on the frontend)
PUBLIC_API_URL=http://localhost:3011

# Database
DATABASE_URL=postgresql://splash:splash_dev_password@localhost:5433/splash_dev?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380

# JWT Authentication
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRATION=30d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# CORS
CORS_ORIGIN=http://localhost:3010

# WebSocket
WS_PORT=3011

# Bull Queue (Redis-backed)
BULL_REDIS_HOST=localhost
BULL_REDIS_PORT=6380

# Logging
LOG_LEVEL=debug

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DEST=./uploads
