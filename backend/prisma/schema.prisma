// ─────────────────────────────────────────────────────────────
// SPLASH – Maritime Chartering Platform
// Prisma Schema
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────── Enums ────────────────

enum CompanyType {
  OWNER
  BROKER
  CHARTERER
  OPERATOR
  OTHER
}

enum UserRole {
  PLATFORM_ADMIN
  COMPANY_ADMIN
  BROKER
  OWNER
  CHARTERER
  OPERATOR
  LEGAL
  READ_ONLY
}

enum VoyageStatus {
  DRAFT
  NEGOTIATING
  FIXED
  PERFORMING
  COMPLETED
  ARCHIVED
}

enum ParticipantRole {
  OWNER
  BROKER
  CHARTERER
  OPERATOR
  LEGAL
  OBSERVER
  ADMIN
}

enum ConversationType {
  INTERNAL
  EXTERNAL
  NEGOTIATION
  EMAIL_SYNC
  CALL_NOTES
}

enum MessageType {
  USER_TEXT
  SYSTEM
  AI_SUMMARY
  EMAIL_IMPORT
  CALL_NOTE
  FILE_NOTE
}

enum MessageSource {
  APP
  EMAIL
  IMPORTED
  SYSTEM
  AI
}

enum TermType {
  VESSEL
  CARGO
  QUANTITY
  LOAD_PORT
  DISCHARGE_PORT
  LAYCAN
  FREIGHT_RATE
  DEMURRAGE
  DESPATCH
  COMMISSION
  PAYMENT_TERMS
  CP_FORM
  OTHER
}

enum ExtractionStatus {
  PROPOSED
  ACCEPTED
  REJECTED
  SUPERSEDED
}

enum ProposedBy {
  AI
  USER
  SYSTEM
}

enum GeneratedBy {
  AI
  USER
}

// ──────────────── Models ────────────────

model Company {
  id          String      @id @default(uuid()) @db.Uuid
  legalName   String
  displayName String
  companyType CompanyType
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  users   User[]
  voyages Voyage[]

  @@map("companies")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @db.Uuid
  firstName    String
  lastName     String
  email        String   @unique
  jobTitle     String?
  passwordHash String
  avatarUrl    String?
  isActive     Boolean  @default(true)
  role         UserRole
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  messages              Message[]
  voyageParticipants    VoyageParticipant[]
  createdVoyages        Voyage[]              @relation("VoyageCreatedBy")
  createdConversations  Conversation[]        @relation("ConversationCreatedBy")
  uploadedFiles         FileAttachment[]
  approvedTerms         ExtractedTerm[]       @relation("TermApprovedBy")
  dealSnapshots         DealSnapshot[]
  recaps                Recap[]
  auditEvents           AuditEvent[]
  emailIntegrationAccounts EmailIntegrationAccount[]
  notifications         Notification[]

  @@index([companyId])
  @@index([email])
  @@map("users")
}

model Voyage {
  id                  String       @id @default(uuid()) @db.Uuid
  companyId           String       @db.Uuid
  internalReference   String
  voyageName          String
  vesselName          String?
  imoNumber           String?
  ownerCompanyName    String?
  chartererCompanyName String?
  brokerCompanyName   String?
  cargoType           String?
  cargoQuantity       String?
  loadPort            String?
  dischargePort       String?
  laycanStart         DateTime?
  laycanEnd           DateTime?
  freightRate         String?
  freightCurrency     String?      @default("USD")
  rateBasis           String?
  status              VoyageStatus
  createdByUserId     String       @db.Uuid
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  company   Company @relation(fields: [companyId], references: [id])
  createdBy User    @relation("VoyageCreatedBy", fields: [createdByUserId], references: [id])

  participants   VoyageParticipant[]
  conversations  Conversation[]
  files          FileAttachment[]
  extractedTerms ExtractedTerm[]
  dealSnapshots  DealSnapshot[]
  recaps         Recap[]
  contracts      ContractDraft[]
  auditEvents    AuditEvent[]
  importedEmails ImportedEmail[]
  notifications  Notification[]

  @@index([companyId])
  @@index([status])
  @@index([createdByUserId])
  @@index([createdAt])
  @@map("voyages")
}

model VoyageParticipant {
  id              String          @id @default(uuid()) @db.Uuid
  voyageId        String          @db.Uuid
  userId          String          @db.Uuid
  role            ParticipantRole
  visibilityLevel String          @default("full")
  createdAt       DateTime        @default(now())

  voyage Voyage @relation(fields: [voyageId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([voyageId])
  @@index([userId])
  @@map("voyage_participants")
}

model Conversation {
  id              String           @id @default(uuid()) @db.Uuid
  voyageId        String           @db.Uuid
  type            ConversationType
  title           String
  createdByUserId String           @db.Uuid
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  voyage    Voyage @relation(fields: [voyageId], references: [id])
  createdBy User   @relation("ConversationCreatedBy", fields: [createdByUserId], references: [id])

  messages       Message[]
  files          FileAttachment[]
  extractedTerms ExtractedTerm[]  @relation("TermSourceConversation")

  @@index([voyageId])
  @@index([createdByUserId])
  @@index([createdAt])
  @@map("conversations")
}

model Message {
  id                String        @id @default(uuid()) @db.Uuid
  conversationId    String        @db.Uuid
  authorUserId      String?       @db.Uuid
  messageType       MessageType
  plainTextBody     String        @db.Text
  richTextBody      String?       @db.Text
  source            MessageSource
  externalMessageId String?
  sentAt            DateTime
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  editedAt          DateTime?
  deletedAt         DateTime?

  author       User?         @relation(fields: [authorUserId], references: [id])
  conversation Conversation  @relation(fields: [conversationId], references: [id])

  extractedTerms  ExtractedTerm[]  @relation("TermSourceMessage")
  fileAttachments FileAttachment[]

  @@index([conversationId])
  @@index([authorUserId])
  @@index([createdAt])
  @@map("messages")
}

model FileAttachment {
  id               String   @id @default(uuid()) @db.Uuid
  voyageId         String   @db.Uuid
  conversationId   String?  @db.Uuid
  messageId        String?  @db.Uuid
  uploadedByUserId String   @db.Uuid
  originalFilename String
  mimeType         String
  fileSizeBytes    Int
  storageKey       String
  createdAt        DateTime @default(now())

  voyage       Voyage        @relation(fields: [voyageId], references: [id])
  conversation Conversation? @relation(fields: [conversationId], references: [id])
  message      Message?      @relation(fields: [messageId], references: [id])
  uploadedBy   User          @relation(fields: [uploadedByUserId], references: [id])

  @@index([voyageId])
  @@index([conversationId])
  @@index([messageId])
  @@map("file_attachments")
}

model ExtractedTerm {
  id                   String           @id @default(uuid()) @db.Uuid
  voyageId             String           @db.Uuid
  sourceMessageId      String?          @db.Uuid
  sourceConversationId String?          @db.Uuid
  termType             TermType
  rawValue             String
  normalizedValue      String?
  confidenceScore      Float?
  extractionStatus     ExtractionStatus
  proposedBy           ProposedBy
  approvedByUserId     String?          @db.Uuid
  createdAt            DateTime         @default(now())
  supersededById       String?          @unique @db.Uuid

  voyage             Voyage        @relation(fields: [voyageId], references: [id])
  sourceMessage      Message?      @relation("TermSourceMessage", fields: [sourceMessageId], references: [id])
  sourceConversation Conversation? @relation("TermSourceConversation", fields: [sourceConversationId], references: [id])
  approvedBy         User?         @relation("TermApprovedBy", fields: [approvedByUserId], references: [id])
  supersededBy       ExtractedTerm? @relation("TermSupersedes", fields: [supersededById], references: [id])
  supersedes         ExtractedTerm? @relation("TermSupersedes")

  @@index([voyageId])
  @@index([sourceMessageId])
  @@index([sourceConversationId])
  @@map("extracted_terms")
}

model DealSnapshot {
  id              String     @id @default(uuid()) @db.Uuid
  voyageId        String     @db.Uuid
  versionNumber   Int
  snapshotJson    Json
  createdBy       ProposedBy
  createdByUserId String?    @db.Uuid
  createdAt       DateTime   @default(now())

  voyage    Voyage @relation(fields: [voyageId], references: [id])
  createdByUser User?  @relation(fields: [createdByUserId], references: [id])

  @@index([voyageId])
  @@map("deal_snapshots")
}

model Recap {
  id              String      @id @default(uuid()) @db.Uuid
  voyageId        String      @db.Uuid
  title           String
  bodyMarkdown    String      @db.Text
  bodyHtml        String?     @db.Text
  versionNumber   Int
  generatedBy     GeneratedBy
  createdByUserId String?     @db.Uuid
  createdAt       DateTime    @default(now())

  voyage        Voyage          @relation(fields: [voyageId], references: [id])
  createdByUser User?           @relation(fields: [createdByUserId], references: [id])
  contracts     ContractDraft[]

  @@index([voyageId])
  @@map("recaps")
}

model AuditEvent {
  id           String   @id @default(uuid()) @db.Uuid
  voyageId     String?  @db.Uuid
  actorUserId  String?  @db.Uuid
  eventType    String
  entityType   String
  entityId     String
  metadataJson Json?
  createdAt    DateTime @default(now())

  voyage Voyage? @relation(fields: [voyageId], references: [id])
  actor  User?   @relation(fields: [actorUserId], references: [id])

  @@index([voyageId])
  @@index([actorUserId])
  @@index([eventType])
  @@index([createdAt])
  @@map("audit_events")
}

model EmailIntegrationAccount {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @db.Uuid
  provider              String
  emailAddress          String
  accessTokenEncrypted  String
  refreshTokenEncrypted String
  tokenExpiresAt        DateTime?
  syncStatus            String   @default("inactive")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id])
  importedEmails ImportedEmail[]

  @@index([userId])
  @@map("email_integration_accounts")
}

model ImportedEmail {
  id                        String   @id @default(uuid()) @db.Uuid
  voyageId                  String?  @db.Uuid
  emailIntegrationAccountId String   @db.Uuid
  externalThreadId          String?
  externalMessageId         String?
  fromAddress               String
  toAddressesJson           Json
  ccAddressesJson           Json?
  subject                   String
  bodyText                  String   @db.Text
  bodyHtml                  String?  @db.Text
  sentAt                    DateTime
  createdAt                 DateTime @default(now())

  voyage                  Voyage?                 @relation(fields: [voyageId], references: [id])
  emailIntegrationAccount EmailIntegrationAccount @relation(fields: [emailIntegrationAccountId], references: [id])

  @@index([voyageId])
  @@index([emailIntegrationAccountId])
  @@map("imported_emails")
}

model ContractDraft {
  id                   String   @id @default(uuid()) @db.Uuid
  voyageId             String   @db.Uuid
  templateName         String
  bodyMarkdown         String   @db.Text
  bodyHtml             String?  @db.Text
  versionNumber        Int
  generatedFromRecapId String?  @db.Uuid
  createdAt            DateTime @default(now())

  voyage            Voyage @relation(fields: [voyageId], references: [id])
  generatedFromRecap Recap? @relation(fields: [generatedFromRecapId], references: [id])

  @@index([voyageId])
  @@map("contract_drafts")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  voyageId  String?  @db.Uuid
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id])
  voyage Voyage? @relation(fields: [voyageId], references: [id])

  @@index([userId])
  @@index([voyageId])
  @@index([createdAt])
  @@map("notifications")
}
